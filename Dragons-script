task.spawn(function()
    while task.wait(3) do
        local tempMobs = {}
        local tempOvos = {}
        local tempPrompts = {}
        
        pcall(function()
            for _, v in ipairs(workspace:GetDescendants()) do
                -- Achar Ovos
                if v:IsA("Model") and v.Name:lower():match("egg") and v:FindFirstChildWhichIsA("BasePart") then
                    table.insert(tempOvos, v)
                
                -- Achar Prompts (Comida/Harvest)
                elseif v:IsA("ProximityPrompt") then
                    table.insert(tempPrompts, v)

                -- Achar Mobs
                elseif v:IsA("Model") and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") and v.Name ~= player.Name then
                    if not Players:GetPlayerFromCharacter(v) and v.Humanoid.Health > 0 then
                        table.insert(tempMobs, v)
                    end
                end
            end
        end)
        
        Cache.Mobs = tempMobs
        Cache.Ovos = tempOvos
        Cache.Prompts = tempPrompts
    end
end)

-- ================= LOOP DE TWEEN E COLETA DOS OVOS =================
task.spawn(function()
    -- Roda super rÃ¡pido (0.1s) para poder spammar o botÃ£o de coletar ao chegar no ovo
    while task.wait(0.1) do
        if not Configs.AutoEgg or #Cache.Ovos == 0 then continue end

        local root = getRoot()
        local hum = getHumanoid()
        if not root or not hum then continue end

        if eggTargetIndex > #Cache.Ovos then eggTargetIndex = 1 end
        local alvo = Cache.Ovos[eggTargetIndex] -- alvo aqui Ã© um "Model"

        -- Pega a parte central do modelo do ovo para voar atÃ© lÃ¡
        local targetPart = alvo and alvo:FindFirstChildWhichIsA("BasePart")

        if alvo and alvo.Parent and targetPart then
            local distancia = (root.Position - targetPart.Position).Magnitude

            if distancia > 10 then
                -- Desmontar do dragÃ£o antes de voar (Evita bugs)
                if hum.Sit then 
                    hum.Sit = false 
                    task.wait(0.2) 
                end

                if not currentTween or currentTween.PlaybackState ~= Enum.PlaybackState.Playing then
                    local tempo = distancia / Configs.TpSpeed
                    local tweenInfo = TweenInfo.new(tempo, Enum.EasingStyle.Linear)
                    
                    currentTween = TweenService:Create(root, tweenInfo, {CFrame = targetPart.CFrame * CFrame.new(0, 3, 0)})
                    currentTween:Play()
                end
            else
                -- CHEGOU NO OVO!
                CancelarTween()
                root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                
                -- Procura o botÃ£o de interaÃ§Ã£o dentro do ovo
                local prompt = alvo:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then 
                    -- HACKS DE COLETA: Tira o tempo de segurar a tecla e ignora paredes
                    prompt.HoldDuration = 0
                    prompt.RequiresLineOfSight = false
                    
                    -- Fica disparando o "E" repetidamente atÃ© o ovo sumir do mapa
                    fireproximityprompt(prompt) 
                end
            end
        else
            -- Ovo sumiu do mapa (foi coletado com sucesso ou despawnou)
            CancelarTween()
            eggTargetIndex = eggTargetIndex + 1
        end
    end
end)

-- ================= LOOP PRINCIPAL (COMBATE E PLAYER) =================
RunService.Heartbeat:Connect(function()
    local root = getRoot()
    local hum = getHumanoid()
    if not root or not hum then return end

    -- Modificadores
    hum.WalkSpeed = Configs.WalkSpeed
    hum.JumpPower = Configs.JumpPower

    -- Noclip (Ativa automÃ¡tico se o TP de ovo estiver rodando)
    if Configs.Noclip or (Configs.AutoEgg and currentTween) then
        for _, v in ipairs(getChar():GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end

    -- Auto Farm
	if Configs.FarmMobs then
		if not currentTarget or not currentTarget.Parent or not currentTarget:FindFirstChild("Humanoid") or currentTarget.Humanoid.Health <= 0 then
            local dist = math.huge
            currentTarget = nil
            for _, mob in ipairs(Cache.Mobs) do
                if mob and mob.Parent and mob:FindFirstChild("HumanoidRootPart") and mob.Humanoid.Health > 0 then
                    local d = (root.Position - mob.HumanoidRootPart.Position).Magnitude
                    if d < dist then
                        dist = d
                        currentTarget = mob
                    end
                end
            end
		end

		if currentTarget then
			local npcRoot = currentTarget:FindFirstChild("HumanoidRootPart")
			if npcRoot then
                root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                root.CFrame = CFrame.new(npcRoot.Position + Vector3.new(0, Configs.FarmHeight, Configs.FarmDistance), npcRoot.Position)
                pcall(function() VirtualUser:ClickButton1(Vector2.new(0,0), Camera.CFrame) end)
			end
		end
	end
end)

-- ================= LOOP DE COLETA (LENTO) =================
task.spawn(function()
    while task.wait(0.5) do
        local root = getRoot()
        if not root then continue end

        -- Coletar (Usa o Cache)
        if Configs.AutoColeta then
            pcall(function()
                for _, prompt in ipairs(Cache.Prompts) do
                    if prompt and prompt.Parent and prompt.Parent:IsA("BasePart") then
                        if (root.Position - prompt.Parent.Position).Magnitude < 40 then 
                            fireproximityprompt(prompt)
                        end
                    end
                end
            end)
        end

        -- Auto Magnet (Puxa moedas soltas)
        if Configs.AutoMagnet then
            pcall(function()
                for _, obj in ipairs(workspace:GetChildren()) do
                    if obj:IsA("BasePart") and (obj.Name:lower():match("coin") or obj.Name:lower():match("meat")) then
                        obj.CFrame = root.CFrame
                    end
                end
            end)
        end
    end
end)

-- ================= ESP (LIMPEZA INTELIGENTE) =================
local function gerenciarESP(objeto, tipo, cor, ativo)
    local part = objeto:IsA("Model") and objeto:FindFirstChildWhichIsA("BasePart") or objeto
    if not part then return end

    if ativo then
        if not ESP_Objects[part] then
            local bill = Instance.new("BillboardGui", part)
            bill.Size = UDim2.new(0, 100, 0, 30)
            bill.AlwaysOnTop = true
            local txt = Instance.new("TextLabel", bill)
            txt.Size = UDim2.new(1, 0, 1, 0)
            txt.BackgroundTransparency = 1
            txt.Text = tipo
            txt.TextColor3 = cor
            txt.Font = Enum.Font.GothamBold
            txt.TextScaled = true
            ESP_Objects[part] = bill
        end
    else
        if ESP_Objects[part] then
            ESP_Objects[part]:Destroy()
            ESP_Objects[part] = nil
        end
    end
end

RunService.RenderStepped:Connect(function()
    -- Limpa ESPs velhos de objetos que foram destruÃ­dos
    for part, gui in pairs(ESP_Objects) do
        if not part or not part.Parent then
            if gui then gui:Destroy() end
            ESP_Objects[part] = nil
        end
